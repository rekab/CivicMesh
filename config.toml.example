# Where the SQLite DB lives. Required, no default. Must be absolute (or
# ~/-prefixed; expanduser resolves it). `civicmesh configure` writes the
# resolved absolute path automatically. Production convention is the /var
# path below; in dev, configure points it at <project_root>/civic_mesh.db.
db_path = "/usr/local/civicmesh/var/civic_mesh.db"

# CivicMesh config. Fields marked [apply] trigger system-file regeneration
# on `civicmesh apply`. Fields marked [runtime] are read by the running
# Python services; edit-and-restart with `systemctl restart civicmesh-*`.

# Identity. site_name is the human-readable name of the physical
# hub/site this node serves (portal masthead, captive-portal
# titles, stamped into session.location for new sessions).
# callsign is the short on-wire identity — firmware sets this as
# the SenderName, which the MeshCore companion app uses as the
# avatar header on every channel post. Tier 1 — civicmesh
# configure prompts for both. [runtime]
[node]
site_name = "Your Hub Name"
# 1-9 chars, [A-Za-z0-9_-]; lowercased on load. Airtime matters
# because this rides every channel message. The 9-char ceiling
# matches the RFC-1459 / EFnet IRC nick convention and stays
# safely under any plausible MeshCore advert-name limit.
callsign = "civic1"

# Network addressing, interface, and DHCP. Consumed by `civicmesh apply`
# to render hostapd / dnsmasq / networkd / nftables. These are pure
# L2/L3 facts — they do not appear in the wireless beacon. Tier 1 —
# civicmesh configure will prompt for ip and iface; the rest are Tier 2.
[network]
ip = "10.0.0.1"                # [apply] dnsmasq, networkd
subnet_cidr = "10.0.0.0/24"    # [apply] dnsmasq (validated; netmask is hardcoded /24 in the renderer)
iface = "wlan0"                # [apply] hostapd, dnsmasq, networkd, NM, nftables, sysctl
country_code = "US"            # [apply] hostapd
dhcp_range_start = "10.0.0.10" # [apply] dnsmasq
dhcp_range_end = "10.0.0.250"  # [apply] dnsmasq
# dnsmasq lease lifetime. Short leases (e.g. 15m) churn the lease table
# faster and free addresses for walk-up clients; longer leases (1h+)
# reduce DHCP traffic. Accepts dnsmasq syntax: 15m, 1h, infinite, etc.
dhcp_lease = "15m"             # [apply] dnsmasq

# Wireless-only concerns. Consumed by `civicmesh apply` (renders
# hostapd.conf). SSID is operator-facing branding; pick something
# walk-up users will recognize on a Wi-Fi list. Tier 1.
[ap]
ssid = "CivicMesh-Messages"    # [apply] hostapd
# 2.4 GHz channel. Use 1, 6, or 11 — the non-overlapping channels for
# 802.11. Other 1–11 values warn but load; outside 1–11 hard-errors.
channel = 6                    # [apply] hostapd

# Radio hardware. serial_port is Tier 1 (auto-detected by civicmesh configure);
# freq/bw/sf/cr are Tier 2 (hand-edit only if your mesh uses non-default params).
# All [radio] fields are [runtime] (consumed by mesh_bot only).
[radio]
# Use the /dev/serial/by-id/... path rather than /dev/ttyUSBN — the by-id
# symlink is stable across USB re-enumeration, so mesh_bot keeps working
# after pyusb resets, cable wiggles, or any other event that renames ttyUSBN.
# Find your device's by-id path with: ls -la /dev/serial/by-id/
serial_port = "/dev/serial/by-id/usb-Silicon_Labs_CP2102_USB_to_UART_Bridge_Controller_XXXXXXXX-if00-port0"
freq_mhz = 910.525
bw_khz = 62.5
sf = 7
cr = 5

# MeshCore channels to join. Tier 1 — civicmesh configure will prompt.
# [runtime] (consumed by mesh_bot).
[channels]
names = ["#civicmesh", "#testing"]

# Device-local channels (never relayed over radio). Tier 2. [runtime].
[local]
names = ["#local"]

# Captive-portal web server. port is Tier 1; portal_aliases is Tier 2.
# The portal host is derived from network.ip — there is no portal_host
# field anymore (CIV-60).
[web]
port = 8080                                # [apply] nftables (port-redirect target)
# Additional hostnames accepted by the portal Host-header check.
# These are aliases for human use (bookmarks, word-of-mouth). Redirects
# and probe responses always use the portal host (network.ip).
# Do NOT use a .local hostname — iOS cannot resolve .local via unicast DNS.
portal_aliases = ["civicmesh.internal"]    # [runtime]

# Rate limits and message constraints. Tier 2.
# All [limits] fields are [runtime] (consumed by web_server and mesh_bot).
[limits]
posts_per_hour = 10
message_max_chars = 100
name_max_chars = 12
name_pattern = "^[A-Za-z0-9_-]+$"
outbox_max_delay_sec = 10
outbox_idle_reset_sec = 60
outbox_max_retries = 3
# Seconds to wait for an echo after no_event_received before retrying.
# Must be < ActiveOutboxIndex lifetime (20s) to catch late echoes.
outbox_echo_wait_sec = 8
retention_bytes_per_channel = 10737418240  # 10GB
# Global mesh egress ceiling (sliding hour). Sized below radio capacity
# (~360/hr at PNW LoRa profile) so the relay does not dominate a shared
# channel even when its outbox is full. Combined with outbox_max_depth this
# is the relay-wide spambot ceiling: per-session throttling can be
# multiplied by free session minting (egress audit F1); this cannot.
global_egress_per_hour = 200
# Hard cap on queued (status='queued') outbox rows. New POSTs above this
# get 429 with retry_after_sec=60 and DO NOT enqueue. Drains in ~18 minutes
# at the global_egress_per_hour rate above — long enough to absorb a normal
# radio reconnect, short enough that a sustained outage cannot store hours
# of work to flood the channel on recovery (egress audit F3).
outbox_max_depth = 60

# Log output. Tier 2. All [logging] fields are [runtime].
[logging]
log_level = "INFO"
# CIV-104: resolved relative to the systemd unit's WorkingDirectory
# (/usr/local/civicmesh) in prod, or the repo root in dev. Lives in
# var/ alongside the DB so runtime state doesn't sit next to code in
# app/.
log_dir = "var/logs"
enable_security_log = true

# Development/testing overrides. Tier 1 — civicmesh configure will prompt.
# [debug] fields are [runtime] (consumed by web_server only).
[debug]
# Allow traffic arriving on eth0 to bypass MAC validation and auto-create sessions for local testing.
# Requires the client to set the civicmesh_session cookie (set by the web UI); only applies when ARP shows eth0.
allow_eth0 = false

# Optional Inkplate 6 e-paper bulletin display for walk-up users.
# Most hubs won't have one. When false (the default), the
# /api/external-display/state endpoint returns 404 and the feature
# imposes no runtime cost. Tier 1 — civicmesh configure asks whether
# this hub has the display attached. [runtime] (consumed by web_server
# only). See docs/external-display-api.md.
[external_display]
enabled = false

# Dev/staging-only diagnostics gate. When true, the mesh-sim injector
# (diagnostics/mesh-sim/inject.py) is allowed to write synthetic mesh
# activity directly to the messages table for UI iteration; a planned
# follow-up adds /api/_test/state for overriding server health fields.
# MUST remain false in production — injection bypasses the radio +
# outbox path and would let any operator scribble fake messages that
# the captive portal then serves. Unknown keys in this section are
# rejected loudly so `enable = true` (typo) doesn't silently default
# off. [runtime] (consumed by diagnostics tooling only).
[diagnostics]
enabled = false

# Optional Victron BMV-712 battery monitor (power_monitor.py). When
# enabled = false (the default), the BLE sampler never starts and the
# node needs none of the [power] dependency extra — most nodes have no
# battery monitor. Set enabled = true ONLY on a node with a BMV, and
# install the deps there: `uv pip install '.[power]'` (pulls bleak +
# pycryptodome; ships aarch64 wheels for offline zero2w). Headless-Pi
# prereq: Bluetooth must be unblocked and up — `rfkill unblock bluetooth`,
# `bluetooth.service` running; a one-time `bluetoothctl` `scan on` may be
# needed before passive scanning works. Full bring-up + key extraction:
# docs/victron-ble-setup.md.
#
# Unknown keys here are rejected loudly (like [diagnostics]): a typo such
# as `address` for `mac` or `key` for `encryption_key` would otherwise
# silently scan/decrypt nothing. This file holds a secret (the key) —
# `chmod 600`. [runtime] (consumed by mesh_bot only).
[power_monitor]
enabled = false
# Source transport. "ble" (passive Victron Instant Readout) is the only
# implemented source. "vedirect" (wired VE.Direct serial) is reserved for
# a future source and currently raises NotImplementedError if selected.
transport = "ble"
# BLE MAC of the BMV (lowercase, colon-separated).
mac = "aa:bb:cc:dd:ee:ff"
# Per-device advertisement encryption key (hex), copied from the
# VictronConnect app (Device > Settings > Product info > "Instant readout
# via Bluetooth"). It is PER DEVICE: re-extract it if the BMV is ever
# swapped, or decryption will silently fail.
encryption_key = "0123456789abcdef0123456789abcdef"
# How often a sample is written to power_samples. The BMV advertises ~1/s;
# we persist at this coarser cadence to avoid DB bloat.
sample_interval_sec = 60
# A reading older than this is treated stale: the sampler logs a gap and
# skips the write, so the latest row's ts marks the last good sample.
stale_after_sec = 180

# CIV-99 wall-clock-correction tuning. CivicMesh maintains its own
# corrected message time using:
#
#   corrected_message_time = int(time.time()) + offset_seconds
#
# Walk-up phones POST their wall clock to /api/clock; the mesh process
# medians the votes into a consensus offset and applies it on every
# stamped DB write. See docs/clock_consensus.md for the full design.
#
# DEPLOYMENT PREREQUISITE (production default): systemd-timesyncd
# .service and chrony.service MUST be persistently masked
# (`sudo systemctl mask <unit>` — no --runtime flag). `civicmesh apply`
# refuses to proceed otherwise. CivicMesh's offset model conflicts
# with any other process stepping the OS clock; persistent masking is
# the structural defense and the runtime external-step detector is
# the safety net.
#
# DEV / RTC OPT-OUT: set `require_timesync_masked = false` below to
# skip the `apply` mask check on machines that intentionally trust
# NTP (dev Pi 4 with internet, RTC-backed hubs). This opt-out ONLY
# affects the apply pre-flight; runtime offset-consensus, the
# external-step detector, and `civicmesh set-clock` are unchanged.
# See docs/clock_consensus.md § "Dev / RTC machines".
#
# Defaults below are reasonable for Pi Zero 2W disaster nodes. Tier 2:
# don't change without reading the design doc. [runtime] (consumed by
# mesh_bot, web_server, civicmesh CLI).
[clock]
# Production-strict mask check. TRUE = `civicmesh apply` refuses to
# run unless systemd-timesyncd and chrony (if installed) are
# persistently masked. FALSE = skip the check. Leave true for offline
# production deployments. See the block comment above.
require_timesync_masked = true
# How often _clock_task evaluates consensus. 60s ≈ the time from a
# walk-up's report being eligible to the next correction tick.
eval_interval_sec = 60
# Distinct cookies (after MAC dedupe) required to accept a correction.
# 3 absorbs one outlier vote via the median while staying achievable
# at a small site.
quorum_min_cookies = 3
# Cookie age gate before a vote counts. Drops noise from first-second
# walk-ups whose clock state is least known.
min_cookie_age_sec = 300
# Reports older than this drop out of consensus. Compared against
# time.monotonic() (not wall) so within-tick frame changes don't flip
# eligibility.
max_report_age_sec = 1800
# ABSOLUTE epoch bounds on corrected wall time. NOT raw-relative: the
# scenario this feature targets is a stale raw clock, so a relative
# ceiling would reject correct phone reports. Bump as the deployment
# ages.
sanity_floor_epoch    = 1704067200  # 2024-01-01 UTC
sanity_ceiling_epoch  = 1862006400  # 2029-01-01 UTC
# Cap on bidirectional nudges after the first consensus correction in
# a boot. 120 absorbs a week+ of Pi-Zero RC drift in a single tick
# while keeping per-tick changes bounded.
max_nudge_sec = 120
# |Δ(time.time() - time.monotonic())| above which the task declares an
# external clock step (NTP came back, manual `date`, etc.). 30 is
# above scheduling jitter and below any meaningful NTP correction.
external_step_threshold_sec = 30
