# Where the SQLite DB lives. Required, no default. Must be absolute (or
# ~/-prefixed; expanduser resolves it). `civicmesh configure` writes the
# resolved absolute path automatically. Production convention is the /var
# path below; in dev, configure points it at <project_root>/civic_mesh.db.
db_path = "/usr/local/civicmesh/var/civic_mesh.db"

# CivicMesh config. Fields marked [apply] trigger system-file regeneration
# on `civicmesh apply`. Fields marked [runtime] are read by the running
# Python services; edit-and-restart with `systemctl restart civicmesh-*`.

# Identity. site_name is the human-readable name of the physical
# hub/site this node serves (portal masthead, captive-portal
# titles, stamped into session.location for new sessions).
# callsign is the short on-wire identity — firmware sets this as
# the SenderName, which the MeshCore companion app uses as the
# avatar header on every channel post. Tier 1 — civicmesh
# configure prompts for both. [runtime]
[node]
site_name = "Your Hub Name"
# 1-9 chars, [A-Za-z0-9_-]; lowercased on load. Airtime matters
# because this rides every channel message. The 9-char ceiling
# matches the RFC-1459 / EFnet IRC nick convention and stays
# safely under any plausible MeshCore advert-name limit.
callsign = "civic1"

# Network addressing, interface, and DHCP. Consumed by `civicmesh apply`
# to render hostapd / dnsmasq / networkd / nftables. These are pure
# L2/L3 facts — they do not appear in the wireless beacon. Tier 1 —
# civicmesh configure will prompt for ip and iface; the rest are Tier 2.
[network]
ip = "10.0.0.1"                # [apply] dnsmasq, networkd
subnet_cidr = "10.0.0.0/24"    # [apply] dnsmasq (validated; netmask is hardcoded /24 in the renderer)
iface = "wlan0"                # [apply] hostapd, dnsmasq, networkd, NM, nftables, sysctl
country_code = "US"            # [apply] hostapd
dhcp_range_start = "10.0.0.10" # [apply] dnsmasq
dhcp_range_end = "10.0.0.250"  # [apply] dnsmasq
# dnsmasq lease lifetime. Short leases (e.g. 15m) churn the lease table
# faster and free addresses for walk-up clients; longer leases (1h+)
# reduce DHCP traffic. Accepts dnsmasq syntax: 15m, 1h, infinite, etc.
dhcp_lease = "15m"             # [apply] dnsmasq

# Wireless-only concerns. Consumed by `civicmesh apply` (renders
# hostapd.conf). SSID is operator-facing branding; pick something
# walk-up users will recognize on a Wi-Fi list. Tier 1.
[ap]
ssid = "CivicMesh-Messages"    # [apply] hostapd
# 2.4 GHz channel. Use 1, 6, or 11 — the non-overlapping channels for
# 802.11. Other 1–11 values warn but load; outside 1–11 hard-errors.
channel = 6                    # [apply] hostapd

# Radio hardware. serial_port is Tier 1 (auto-detected by civicmesh configure);
# freq/bw/sf/cr are Tier 2 (hand-edit only if your mesh uses non-default params).
# All [radio] fields are [runtime] (consumed by mesh_bot only).
[radio]
# Use the /dev/serial/by-id/... path rather than /dev/ttyUSBN — the by-id
# symlink is stable across USB re-enumeration, so mesh_bot keeps working
# after pyusb resets, cable wiggles, or any other event that renames ttyUSBN.
# Find your device's by-id path with: ls -la /dev/serial/by-id/
serial_port = "/dev/serial/by-id/usb-Silicon_Labs_CP2102_USB_to_UART_Bridge_Controller_XXXXXXXX-if00-port0"
freq_mhz = 910.525
bw_khz = 62.5
sf = 7
cr = 5

# MeshCore channels to join. Tier 1 — civicmesh configure will prompt.
# [runtime] (consumed by mesh_bot).
[channels]
names = ["#civicmesh", "#testing"]

# Device-local channels (never relayed over radio). Tier 2. [runtime].
[local]
names = ["#local"]

# Captive-portal web server. port is Tier 1; portal_aliases is Tier 2.
# The portal host is derived from network.ip — there is no portal_host
# field anymore (CIV-60).
[web]
port = 8080                                # [apply] nftables (port-redirect target)
# Additional hostnames accepted by the portal Host-header check.
# These are aliases for human use (bookmarks, word-of-mouth). Redirects
# and probe responses always use the portal host (network.ip).
# Do NOT use a .local hostname — iOS cannot resolve .local via unicast DNS.
portal_aliases = ["civicmesh.internal"]    # [runtime]

# Rate limits and message constraints. Tier 2.
# All [limits] fields are [runtime] (consumed by web_server and mesh_bot).
[limits]
posts_per_hour = 10
message_max_chars = 100
name_max_chars = 12
name_pattern = "^[A-Za-z0-9_-]+$"
outbox_max_delay_sec = 10
outbox_idle_reset_sec = 60
outbox_max_retries = 3
# Seconds to wait for an echo after no_event_received before retrying.
# Must be < ActiveOutboxIndex lifetime (20s) to catch late echoes.
outbox_echo_wait_sec = 8
retention_bytes_per_channel = 10737418240  # 10GB
# Global mesh egress ceiling (sliding hour). Sized below radio capacity
# (~360/hr at PNW LoRa profile) so the relay does not dominate a shared
# channel even when its outbox is full. Combined with outbox_max_depth this
# is the relay-wide spambot ceiling: per-session throttling can be
# multiplied by free session minting (egress audit F1); this cannot.
global_egress_per_hour = 200
# Hard cap on queued (status='queued') outbox rows. New POSTs above this
# get 429 with retry_after_sec=60 and DO NOT enqueue. Drains in ~18 minutes
# at the global_egress_per_hour rate above — long enough to absorb a normal
# radio reconnect, short enough that a sustained outage cannot store hours
# of work to flood the channel on recovery (egress audit F3).
outbox_max_depth = 60

# Log output. Tier 2. All [logging] fields are [runtime].
[logging]
log_level = "INFO"
log_dir = "logs"
enable_security_log = true

# Development/testing overrides. Tier 1 — civicmesh configure will prompt.
# [debug] fields are [runtime] (consumed by web_server only).
[debug]
# Allow traffic arriving on eth0 to bypass MAC validation and auto-create sessions for local testing.
# Requires the client to set the civicmesh_session cookie (set by the web UI); only applies when ARP shows eth0.
allow_eth0 = false

# Optional Inkplate 6 e-paper bulletin display for walk-up users.
# Most hubs won't have one. When false (the default), the
# /api/external-display/state endpoint returns 404 and the feature
# imposes no runtime cost. Tier 2 — hand-edit only on hubs that
# physically have the display. [runtime] (consumed by web_server
# only). See docs/external-display-api.md.
[external_display]
enabled = false
