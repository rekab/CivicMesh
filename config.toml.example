# Identity and location. Tier 1 — civicmesh configure will prompt for these.
[node]
name = "CivicMesh"
location = "Your Hub, Your City"  # Used for session location metadata; changing it will only affect new/updated sessions.

# Network addressing, interface, and DHCP. Consumed by `civicmesh apply`
# to render hostapd / dnsmasq / networkd / nftables. These are pure
# L2/L3 facts — they do not appear in the wireless beacon. Tier 1 —
# civicmesh configure will prompt for ip and iface; the rest are Tier 2.
[network]
ip = "10.0.0.1"
subnet_cidr = "10.0.0.0/24"
iface = "wlan0"
country_code = "US"
dhcp_range_start = "10.0.0.10"
dhcp_range_end = "10.0.0.250"
# dnsmasq lease lifetime. Short leases (e.g. 15m) churn the lease table
# faster and free addresses for walk-up clients; longer leases (1h+)
# reduce DHCP traffic. Accepts dnsmasq syntax: 15m, 1h, infinite, etc.
dhcp_lease = "15m"

# Wireless-only concerns. Consumed by `civicmesh apply` (renders
# hostapd.conf). SSID is operator-facing branding; pick something
# walk-up users will recognize on a Wi-Fi list. Tier 1.
[ap]
ssid = "CivicMesh-Messages"
# 2.4 GHz channel. Use 1, 6, or 11 — the non-overlapping channels for
# 802.11. Other 1–11 values warn but load; outside 1–11 hard-errors.
channel = 6

# Radio hardware. serial_port is Tier 1 (auto-detected by civicmesh configure);
# freq/bw/sf/cr are Tier 2 (hand-edit only if your mesh uses non-default params).
[radio]
# Use the /dev/serial/by-id/... path rather than /dev/ttyUSBN — the by-id
# symlink is stable across USB re-enumeration, so mesh_bot keeps working
# after pyusb resets, cable wiggles, or any other event that renames ttyUSBN.
# Find your device's by-id path with: ls -la /dev/serial/by-id/
serial_port = "/dev/serial/by-id/usb-Silicon_Labs_CP2102_USB_to_UART_Bridge_Controller_XXXXXXXX-if00-port0"
freq_mhz = 910.525
bw_khz = 62.5
sf = 7
cr = 5

# MeshCore channels to join. Tier 1 — civicmesh configure will prompt.
[channels]
names = ["#civicmesh", "#testing"]

# Device-local channels (never relayed over radio). Tier 2.
[local]
names = ["#local"]

# Captive-portal web server. port is Tier 1; portal_aliases is Tier 2.
# The portal host is derived from network.ip — there is no portal_host
# field anymore (CIV-60).
[web]
port = 8080
# Additional hostnames accepted by the portal Host-header check.
# These are aliases for human use (bookmarks, word-of-mouth). Redirects
# and probe responses always use the portal host (network.ip).
# Do NOT use a .local hostname — iOS cannot resolve .local via unicast DNS.
portal_aliases = ["civicmesh.internal"]

# Rate limits and message constraints. Tier 2.
[limits]
posts_per_hour = 10
message_max_chars = 100
name_max_chars = 12
name_pattern = "^[A-Za-z0-9_-]+$"
outbox_max_delay_sec = 10
outbox_idle_reset_sec = 60
outbox_max_retries = 3
# Seconds to wait for an echo after no_event_received before retrying.
# Must be < ActiveOutboxIndex lifetime (20s) to catch late echoes.
outbox_echo_wait_sec = 8
retention_bytes_per_channel = 10737418240  # 10GB

# Log output. Tier 2.
[logging]
log_level = "INFO"
log_dir = "logs"
enable_security_log = true

# Development/testing overrides. Tier 1 — civicmesh configure will prompt.
[debug]
# Allow traffic arriving on eth0 to bypass MAC validation and auto-create sessions for local testing.
# Requires the client to set the civicmesh_session cookie (set by the web UI); only applies when ARP shows eth0.
allow_eth0 = false
