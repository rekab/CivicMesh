# Output from `diagnostics/radio/*.py` runs (tee'd to dated .log files at
# the repo root by convention). Contains captured ciphertexts, decrypted
# plaintexts, and — in the case of manual_decrypt.py — the radio's
# exported X25519 private key. Per-run only; never source.
/*.lo*

# CivicMesh radio diagnostics — harness source is tracked, runs are not.
diagnostics/radio/runs/*
!diagnostics/radio/runs/.gitkeep
# Per-operator node settings; copy nodes.toml.example to start.
diagnostics/radio/nodes.toml
# mesh-sim injector sidecar — per-checkout state listing the messages.id
# values of the rows the injector inserted, so --replace-injected knows
# which rows it owns. Per-run, not source.
diagnostics/mesh-sim/.injected_ids.json
# Hub Reference Library (CIV-90)
out/
var/
content/hub-docs/*.pdf

# Inkplate host PNG renderer build artifacts. Vendor sources under
# inkplate/host/vendor/ ARE committed; only the build outputs are not.
# Fixtures' expected.png files are committed (they're golden test data).
inkplate/host/host_render
inkplate/host/*.o
inkplate/host/main.dSYM/
# Output from inkplate/tools/contact-sheet.py — per-run PNGs + index.html.
# Wiped and rewritten on each invocation; never source.
.contact/
